{
  "name": "server",
  "version": "1.0.0",
  "main": "./src/server.js",
  "scripts": {
    "start": "node ./src/server.js",
    "dev": "nodemon ./src/server.js",
    "lint": "eslint 'src/**/*.js'",
    "lint-fix": "eslint --fix 'src/**/*.js'",
    "test": "cross-env NODE_ENV=test jest --watch",
    "test:staged": "cross-env NODE_ENV=true jest --findRelatedTests",
    "format": "prettier --write 'src/**/*.js'"
  },
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-jwt": "^8.5.1",
    "jwks-rsa": "^4.0.1",
    "mongoose": "^9.4.1"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.3.0",
    "kill-port": "^2.0.1",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2"
  }
}
