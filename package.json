{
  "name": "budget-tracker",
  "version": "1.0.0",
  "author": "Ahsan",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "./packages/client",
    "./packages/server"
  ],
  "scripts": {
    "client": "yarn workspace client start",
    "server": "yarn workspace server dev",
    "prepare": "husky",
    "dev": "concurrently -k \"yarn server\" \"yarn client\""
  },
  "lint-staged": {
    "*.{js}": [
      "prettier --write",
      "eslint --fix"
    ],
    "packages/client/**/*.js": [
      "yarn --cwd packages/client test:staged"
    ],
    "packages/server/**/*.js": [
      "yarn --cwd packages/server test:staged"
    ],
    "*.{html,json}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "resolutions": {
    "path-to-regexp": "^8.4.0",
    "brace-expansion": "^1.1.13",
    "picomatch": "^2.3.2",
    "yaml": "^1.10.3",
    "flatted": "^3.4.2",
    "yauzl": "^3.2.1",
    "undici": "^7.24.1",
    "tar": "^7.5.11",
    "lodash": "^4.18.1"
  },
  "packageManager": "yarn@4.12.0"
}
