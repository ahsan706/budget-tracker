{
  "name": "budget-tracker",
  "version": "1.0.0",
  "author": "Ahsan",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "./packages/client",
    "./packages/server"
  ],
  "scripts": {
    "client": "yarn workspace client start",
    "server": "yarn workspace server dev",
    "prepare": "husky",
    "dev": "concurrently -k \"yarn server\" \"yarn client\""
  },
  "lint-staged": {
    "*.{js}": [
      "prettier --write",
      "eslint --fix"
    ],
    "packages/client/**/*.js": [
      "yarn --cwd packages/client test:staged"
    ],
    "packages/server/**/*.js": [
      "yarn --cwd packages/server test:staged"
    ],
    "*.{html,json}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  },
  "resolutions": {
    "braces": "3.0.3",
    "micromatch": "4.0.8",
    "cross-spawn": "7.0.6",
    "follow-redirects": "1.15.11",
    "@babel/traverse": "7.29.0",
    "@babel/runtime": "7.28.6",
    "@babel/helpers": "7.28.6",
    "minimatch@^3.0.4": "3.1.3",
    "brace-expansion@^1.1.7": "1.1.12",
    "semver@^6.0.0": "6.3.1",
    "semver@^6.3.0": "6.3.1",
    "semver@^7.3.2": "7.7.4",
    "loader-utils@^2.0.0": "2.0.4",
    "minimist@^1.2.0": "1.2.8",
    "minimist@^1.2.5": "1.2.8",
    "json5@^2.1.2": "2.2.3",
    "ansi-regex@^5.0.0": "5.0.1",
    "tmpl@1.0.x": "1.0.5",
    "form-data@^3.0.0": "3.0.4",
    "lodash": "4.17.23",
    "ajv@^6.12.4": "6.14.0",
    "ajv@^6.12.5": "6.14.0",
    "js-yaml@^3.13.1": "3.14.2",
    "browserslist@^4.0.0": "4.16.5",
    "on-headers": "1.1.0",
    "nth-check": "2.1.1"
  },
  "packageManager": "yarn@4.12.0"
}
