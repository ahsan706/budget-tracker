{
  "name": "budget-tracker",
  "version": "1.0.0",
  "author": "Ahsan",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "./packages/client",
    "./packages/server"
  ],
  "scripts": {
    "client": "yarn workspace client start",
    "server": "yarn workspace server dev",
    "prepare": "husky",
    "dev": "concurrently -k \"yarn server\" \"yarn client\""
  },
  "lint-staged": {
    "*.{js}": [
      "prettier --write",
      "eslint --fix"
    ],
    "packages/client/**/*.js": [
      "yarn --cwd packages/client test:staged"
    ],
    "packages/server/**/*.js": [
      "yarn --cwd packages/server test:staged"
    ],
    "*.{html,json}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  },
  "packageManager": "yarn@4.12.0"
}
